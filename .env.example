# ── Site ─────────────────────────────────────────────────────────────────────
# Your production domain — used for canonical URLs, Open Graph, and sitemap.
# No trailing slash.
SITE_URL=https://elohimreformas.com

# ── Google Places API ────────────────────────────────────────────────────────
# Get your API key: https://console.cloud.google.com → APIs & Services → Credentials
# Enable "Places API" for the key.
#
# Get your Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id
# Or search here: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
#
GOOGLE_PLACES_API_KEY=your_api_key_here
GOOGLE_PLACE_ID=your_place_id_here
