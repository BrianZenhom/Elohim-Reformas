---
import Phone from "../assets/phone.svg";
import Mail from "../assets/mail.svg";
import Whatsapp from "../assets/whatsapp.svg";
import Clock from "../assets/clock.svg";
---

<section class="loc-section" id="location">
  <div class="loc-inner">

    <!-- Left column: contact info -->
    <div class="loc-left">

      <div class="loc-header">
        <span class="loc-eyebrow">Estamos para ayudarte</span>
        <h2 class="loc-title">Contáctanos</h2>
        <p class="loc-subtitle">
          Cuéntanos tu proyecto y te respondemos en menos de 24 horas.
        </p>
      </div>

      <div class="loc-cards">

        <a class="loc-card" href="tel:+34624350394">
          <div class="loc-card-icon loc-card-icon--phone">
            <Phone />
          </div>
          <div class="loc-card-body">
            <span class="loc-card-label">Teléfono</span>
            <span class="loc-card-value">+34 624 350 394</span>
          </div>
        </a>

        <a class="loc-card" href="mailto:contacto@elohimreformas.com">
          <div class="loc-card-icon loc-card-icon--mail">
            <Mail />
          </div>
          <div class="loc-card-body">
            <span class="loc-card-label">Correo electrónico</span>
            <span class="loc-card-value">contacto@elohimreformas.com</span>
          </div>
        </a>

        <div class="loc-card loc-card--hours">
          <div class="loc-card-icon loc-card-icon--clock">
            <Clock />
          </div>
          <div class="loc-card-body">
            <span class="loc-card-label">Horario de atención</span>
            <span class="loc-card-value">Lun – Vie: 8:00 am – 6:00 pm</span>
            <span class="loc-card-sub">Sáb: 8:00 am – 1:00 pm</span>
          </div>
        </div>

      </div>

      <a
        class="loc-whatsapp"
        href="https://wa.me/34624350394?text=Hola%2C%20me%20gustar%C3%ADa%20obtener%20m%C3%A1s%20informaci%C3%B3n%20sobre%20sus%20servicios."
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="loc-whatsapp-icon"><Whatsapp /></div>
        <span>Escríbenos por WhatsApp</span>
        <svg class="loc-whatsapp-arrow" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
      </a>

    </div>

    <!-- Right column: map -->
    <div class="loc-right">
      <div class="loc-map-wrap">
        <div class="loc-map-header">
          <svg class="loc-pin" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z" />
          </svg>
          <div>
            <span class="loc-map-title">Nuestra oficina</span>
            <span class="loc-map-address">Madrid, España</span>
          </div>
        </div>
        <div class="loc-map-frame">
          <div id="loc-leaflet" style="width:100%;height:100%;"></div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- Leaflet -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>

<style>
  .loc-section {
    background-color: #f5efe7;
    width: 100%;
  }

  .loc-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 5rem 2rem;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 3.5rem;
    align-items: start;
  }

  /* ── Left ── */
  .loc-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .loc-eyebrow {
    font-family: "Onest", sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: #e98a15;
  }

  .loc-title {
    font-family: "Onest", sans-serif;
    font-size: 38px;
    font-weight: 700;
    color: #1a3347;
    line-height: 1.1;
    margin: 0;
  }

  .loc-subtitle {
    font-family: "Roboto", sans-serif;
    font-size: 15px;
    color: #929292;
    line-height: 1.6;
    margin: 0;
  }

  /* ── Contact cards ── */
  .loc-cards {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .loc-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    background: #ffffff;
    border: 1px solid rgba(26, 51, 71, 0.08);
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    line-height: normal;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
  }

  .loc-card:not(.loc-card--hours):hover {
    border-color: rgba(233, 138, 21, 0.4);
    box-shadow: 0 6px 24px rgba(233, 138, 21, 0.1);
    transform: translateY(-2px);
  }

  .loc-card-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 20px;
  }

  .loc-card-icon--phone { background: rgba(233, 138, 21, 0.1); color: #e98a15; }
  .loc-card-icon--mail  { background: rgba(74, 143, 231, 0.1); color: #4a8fe7; }
  .loc-card-icon--clock { background: rgba(45, 158, 107, 0.1); color: #2d9e6b; }

  .loc-card-icon :global(svg) {
    width: 20px;
    height: 20px;
  }

  .loc-card-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
    flex: 1;
  }

  .loc-card-label {
    font-family: "Onest", sans-serif;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #929292;
  }

  .loc-card-value {
    font-family: "Onest", sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #1a3347;
    overflow-wrap: break-word;
    word-break: break-all;
  }

  .loc-card-sub {
    font-family: "Roboto", sans-serif;
    font-size: 13px;
    color: #929292;
  }

  /* ── WhatsApp CTA ── */
  .loc-whatsapp {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    background: #25d366;
    border-radius: 14px;
    text-decoration: none;
    color: #ffffff;
    font-family: "Onest", sans-serif;
    font-size: 15px;
    font-weight: 600;
    line-height: normal;
    transition:
      background 0.25s ease,
      transform 0.25s ease,
      box-shadow 0.25s ease;
    width: fit-content;
  }

  .loc-whatsapp:hover {
    background: #1ebe5d;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(37, 211, 102, 0.35);
  }

  .loc-whatsapp-icon {
    font-size: 22px;
    display: flex;
    align-items: center;
  }

  .loc-whatsapp-icon :global(svg) { width: 22px; height: 22px; }

  .loc-whatsapp-arrow {
    width: 16px;
    height: 16px;
    margin-left: auto;
    opacity: 0.8;
  }

  /* ── Right / Map ── */
  .loc-right {
    position: sticky;
    top: 90px;
  }

  .loc-map-wrap {
    background: #ffffff;
    border: 1px solid rgba(26, 51, 71, 0.08);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(26, 51, 71, 0.08);
  }

  .loc-map-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid rgba(26, 51, 71, 0.06);
  }

  .loc-pin { width: 22px; height: 22px; color: #e98a15; flex-shrink: 0; }

  .loc-map-header > div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .loc-map-title {
    font-family: "Onest", sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #1a3347;
  }

  .loc-map-address {
    font-family: "Roboto", sans-serif;
    font-size: 12px;
    color: #929292;
  }

  .loc-map-frame {
    width: 100%;
    height: 380px;
  }

  /* Leaflet overrides — keep popup & controls on-brand */
  :global(.leaflet-popup-content-wrapper) {
    border-radius: 12px !important;
    box-shadow: 0 8px 32px rgba(26, 51, 71, 0.18) !important;
    font-family: "Onest", sans-serif !important;
  }

  :global(.leaflet-popup-content) {
    font-size: 13px !important;
    color: #1a3347 !important;
    line-height: 1.5 !important;
    margin: 10px 14px !important;
  }

  :global(.leaflet-popup-tip) {
    background: #ffffff !important;
  }

  :global(.leaflet-control-zoom a) {
    color: #1a3347 !important;
    font-family: "Onest", sans-serif !important;
  }

  :global(.leaflet-control-attribution) {
    font-size: 9px !important;
    background: rgba(255, 255, 255, 0.5) !important;
    color: rgba(0, 0, 0, 0.35) !important;
    padding: 1px 4px !important;
    backdrop-filter: blur(4px);
  }

  :global(.leaflet-control-attribution a) {
    color: rgba(0, 0, 0, 0.4) !important;
  }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .loc-inner {
      grid-template-columns: 1fr;
      padding: 3.5rem 1.25rem;
      gap: 2.5rem;
    }

    .loc-title { font-size: 26px; }
    .loc-subtitle { font-size: 14px; }
    .loc-card-value { font-size: 14px; }
    .loc-card-label { font-size: 10px; }
    .loc-whatsapp { font-size: 14px; }
    .loc-right { position: static; }
    .loc-map-frame { height: 280px; }

    .loc-whatsapp {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    var LAT = 40.4168;
    var LNG = -3.7038;

    var map = L.map("loc-leaflet", {
      center: [LAT, LNG],
      zoom: 14,
      zoomControl: true,
      scrollWheelZoom: false,
    });

    L.tileLayer("https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png", {
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: "abcd",
      maxZoom: 20,
    }).addTo(map);

    var markerIcon = L.divIcon({
      html: '<svg width="36" height="48" viewBox="0 0 36 48" fill="none" xmlns="http://www.w3.org/2000/svg"><defs><filter id="ms" x="-40%" y="-20%" width="180%" height="160%"><feDropShadow dx="0" dy="3" stdDeviation="3" flood-color="#00000033"/></filter></defs><path d="M18 0C8.059 0 0 8.059 0 18c0 13.5 18 30 18 30S36 31.5 36 18C36 8.059 27.941 0 18 0z" fill="#e98a15" filter="url(#ms)"/><circle cx="18" cy="18" r="8" fill="white"/><circle cx="18" cy="18" r="4.5" fill="#e98a15"/></svg>',
      className: "",
      iconSize: [36, 48],
      iconAnchor: [18, 48],
      popupAnchor: [0, -50],
    });

    L.marker([LAT, LNG], { icon: markerIcon })
      .addTo(map)
      .bindPopup("<strong>Elohim Reformas</strong><br>Madrid, España")
      .openPopup();
  });
</script>
