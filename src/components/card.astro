---
interface Props {
  title: string;
  description: string;
  image?: string;
  icon?: any;
}

const { title, description, image, icon: Icon } = Astro.props;
---

<div class="card">
  <img src={image} alt={title} />
  {
    Icon && (
      <div class="card-badge">
        <Icon aria-hidden="true" />
      </div>
    )
  }
  <div class="card-content">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</div>

<style>
  .card {
    flex: 1;
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    height: 320px;
    cursor: pointer;
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease;
    box-shadow: 0 4px 24px rgba(26, 51, 71, 0.1);
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(26, 51, 71, 0.22);
  }

  .card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    transition: transform 0.5s ease;
  }

  .card:hover img {
    transform: scale(1.05);
  }

  .card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 20%,
      rgba(8, 16, 32, 0.55) 58%,
      rgba(8, 16, 32, 0.9) 100%
    );
    z-index: 1;
  }

  .card-badge {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 2;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 50%;
    width: 46px;
    height: 46px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: background 0.3s ease;
  }

  .card:hover .card-badge {
    background: rgba(233, 138, 21, 0.3);
    border-color: rgba(233, 138, 21, 0.5);
  }

  .card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 1.75rem;
    color: white;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .card-content h3 {
    font-size: 18px;
    font-weight: 700;
    font-family: "Onest", sans-serif;
    letter-spacing: 0.3px;
  }

  .card-content p {
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.72);
    font-family: "Roboto", sans-serif;
  }
</style>
