    font-size: 15px;
    color: rgba(255, 255, 255, 0.45);
    line-height: 1.5;
    margin: 0;
  }

  .ts-aggregate {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
    flex-shrink: 0;
  }

  .ts-agg-stars {
