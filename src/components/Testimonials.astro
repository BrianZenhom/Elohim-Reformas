---
// ─────────────────────────────────────────────────────────────────────────────
// Google Places API integration
// Runs at BUILD TIME — reviews are baked into the HTML.
// To refresh reviews, just rebuild the site (pnpm build).
//
// Setup:
//   1. Add GOOGLE_PLACES_API_KEY and GOOGLE_PLACE_ID to your .env file
//   2. Run `pnpm build` — reviews are fetched automatically
//   3. Without the keys, the fallback static reviews below are used
// ─────────────────────────────────────────────────────────────────────────────

interface GoogleReview {
  author_name: string;
  rating: number;
  text: string;
  relative_time_description: string;
  profile_photo_url: string;
  time: number;
}

interface Review {
  author_name: string;
  rating: number;
  text: string;
  relative_time_description?: string;
  profile_photo_url?: string;
  badgeColor: string;
}

// Palette cycled over reviews when no photo is available
const BADGE_COLORS = ["#e98a15", "#4a8fe7", "#2d9e6b", "#9b5de5", "#e05c5c", "#2ec4b6"];

const fallbackReviews: Review[] = [
  {
    author_name: "Angie F.",
    rating: 5,
    text: "Estoy muy contenta con mi cocina, ahora es el área que más disfruto en mi casa. El resultado superó todas mis expectativas.",
    relative_time_description: "hace 2 meses",
    badgeColor: "#e98a15",
  },
  {
    author_name: "Brian Z.",
    rating: 5,
    text: "Elohim superó todas mis expectativas. Me dijeron 2 semanas y en 1 semana terminaron la obra. Profesionalismo total.",
    relative_time_description: "hace 3 meses",
    badgeColor: "#4a8fe7",
  },
  {
    author_name: "Luis H.",
    rating: 5,
    text: "No tenía claro cómo quería mi baño, pero ejecutaron todo tal cual. El resultado era exactamente el mismo que me mostraron.",
    relative_time_description: "hace 1 mes",
    badgeColor: "#2d9e6b",
  },
  {
    author_name: "Carlos S.",
    rating: 5,
    text: "Con su ayuda logramos nuestro sueño. Cada detalle fue cuidado con precisión y el equipo siempre estuvo disponible.",
    relative_time_description: "hace 4 meses",
    badgeColor: "#9b5de5",
  },
];

// ── Fetch from Google Places API at build time ────────────────────────────────
async function fetchGoogleReviews(): Promise<Review[]> {
  const apiKey = import.meta.env.GOOGLE_PLACES_API_KEY;
  const placeId = import.meta.env.GOOGLE_PLACE_ID;

  if (!apiKey || !placeId) return fallbackReviews;

  try {
    const url =
      `https://maps.googleapis.com/maps/api/place/details/json` +
      `?place_id=${encodeURIComponent(placeId)}` +
      `&fields=reviews` +
      `&language=es` +        // returns relative_time_description in Spanish
      `&reviews_sort=newest` + // newest first
      `&key=${apiKey}`;

    const res = await fetch(url);
    if (!res.ok) throw new Error(`HTTP ${res.status}`);

    const data = await res.json();
    if (data.status !== "OK") throw new Error(`Places API: ${data.status}`);

    const googleReviews: GoogleReview[] = data.result?.reviews ?? [];

    // Only show 5-star reviews; fall back if none
    const fiveStars = googleReviews.filter((r) => r.rating === 5);
    const source = fiveStars.length >= 2 ? fiveStars : googleReviews;
    if (source.length === 0) return fallbackReviews;

    return source.map((r, i): Review => ({
      author_name: r.author_name,
      rating: r.rating,
      text: r.text,
      relative_time_description: r.relative_time_description,
      profile_photo_url: r.profile_photo_url,
      badgeColor: BADGE_COLORS[i % BADGE_COLORS.length],
    }));
  } catch (err) {
    console.warn("[Testimonials] Google Places fetch failed, using fallback:", err);
    return fallbackReviews;
  }
}

const reviews = await fetchGoogleReviews();
---

<section id="testimonios" class="ts-wrap">
  <div class="ts-inner">

    <!-- Header -->
    <header class="ts-header">
      <div class="ts-header-left">
        <span class="ts-eyebrow">Lo que dicen nuestros clientes</span>
        <h2 class="ts-title">Testimonios</h2>
        <p class="ts-subtitle">Cada proyecto es una historia. Aquí están las de nuestros clientes.</p>
      </div>
      <div class="ts-aggregate">
        <div class="ts-agg-stars">
          {[0,1,2,3,4].map(() => (
            <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.967a1 1 0 00.95.69h4.175c.969 0 1.371 1.24.588 1.81l-3.38 2.456a1 1 0 00-.364 1.118l1.287 3.966c.3.922-.755 1.688-1.54 1.118l-3.38-2.455a1 1 0 00-1.175 0l-3.38 2.455c-.784.57-1.838-.196-1.539-1.118l1.287-3.966a1 1 0 00-.364-1.118L2.05 9.394c-.783-.57-.38-1.81.588-1.81h4.175a1 1 0 00.95-.69l1.286-3.967z" />
            </svg>
          ))}
        </div>
        <span class="ts-agg-num">5.0</span>
        <span class="ts-agg-label">valoración media</span>
      </div>
    </header>

    <!-- Carousel -->
    <div class="ts-carousel-outer">
      <div class="ts-track" id="ts-track">
        {reviews.map((r) => (
          <article class="ts-card">
            <div class="ts-card-top">
              <div class="ts-card-stars">
                {[0,1,2,3,4].map(() => (
                  <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.967a1 1 0 00.95.69h4.175c.969 0 1.371 1.24.588 1.81l-3.38 2.456a1 1 0 00-.364 1.118l1.287 3.966c.3.922-.755 1.688-1.54 1.118l-3.38-2.455a1 1 0 00-1.175 0l-3.38 2.455c-.784.57-1.838-.196-1.539-1.118l1.287-3.966a1 1 0 00-.364-1.118L2.05 9.394c-.783-.57-.38-1.81.588-1.81h4.175a1 1 0 00.95-.69l1.286-3.967z" />
                  </svg>
                ))}
              </div>
              <span class="ts-card-quote">&ldquo;</span>
            </div>
            <p class="ts-card-text">{r.text}</p>
            <footer class="ts-card-footer">
              <div class="ts-card-divider"></div>
              <div class="ts-card-author">
                <div
                  class="ts-card-badge"
                  style={`--bc:${r.badgeColor ?? "#e98a15"}`}
                >
                  {r.author_name.charAt(0).toUpperCase()}
                </div>
                <div class="ts-card-info">
                  <span class="ts-card-name">{r.author_name}</span>
                  {r.relative_time_description && (
                    <span class="ts-card-time">{r.relative_time_description}</span>
                  )}
                </div>
              </div>
            </footer>
          </article>
        ))}
      </div>
    </div>

    <!-- Controls -->
    <div class="ts-controls">
      <button class="ts-btn ts-btn-prev" id="ts-prev" aria-label="Anterior">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6" />
        </svg>
      </button>
      <div class="ts-dots" id="ts-dots">
        {reviews.map((_, i) => (
          <button class={`ts-dot${i === 0 ? " ts-dot--active" : ""}`} data-index={i} aria-label={`Testimonio ${i + 1}`}></button>
        ))}
      </div>
      <button class="ts-btn ts-btn-next" id="ts-next" aria-label="Siguiente">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6" />
        </svg>
      </button>
    </div>

    <!-- Bottom CTA -->
    <div class="ts-cta-row">
      <button
        class="ts-cta-btn"
        onclick="window.open('https://wa.me/34624350394?text=Hola%2C%20me%20gustar%C3%ADa%20obtener%20m%C3%A1s%20informaci%C3%B3n%20sobre%20sus%20servicios.', '_blank')"
      >¡Quiero mi presupuesto gratis!</button>
    </div>

  </div>
</section>

<style>
  /* ── Wrapper ── */
