  .ts-btn:disabled {
    opacity: 0.3;
    pointer-events: none;
  }

  .ts-dots {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ts-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.22);
    cursor: pointer;
    padding: 0;
    transition:
      background 0.25s ease,
      transform 0.25s ease,
      width 0.25s ease;
  }

  .ts-dot--active {
    background: #e98a15;
    width: 24px;
    border-radius: 4px;
    transform: none;
  }

  /* ── Bottom CTA ── */
  .ts-cta-row {
    display: flex;
    justify-content: center;
  }

  .ts-cta-btn {
    padding: 1rem 2.5rem;
    background-color: #e98a15;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-family: "Onest", sans-serif;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.5px;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .ts-cta-btn:hover {
    background-color: #d4790f;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(233, 138, 21, 0.4);
  }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .ts-inner {
      padding: 3.5rem 1.25rem;
      gap: 2.5rem;
    }

    .ts-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .ts-title {
      font-size: 26px;
    }

    .ts-aggregate {
      flex-direction: row;
      align-items: center;
      gap: 0.75rem;
    }

    .ts-agg-num {
      font-size: 26px;
    }
  }
</style>

<script>
  import gsap from "gsap";

  const track = document.getElementById("ts-track") as HTMLElement;
  const prevBtn = document.getElementById("ts-prev") as HTMLButtonElement;
  const nextBtn = document.getElementById("ts-next") as HTMLButtonElement;
  const dotsContainer = document.getElementById("ts-dots") as HTMLElement;

  const cards = Array.from(track.children) as HTMLElement[];
  const total = cards.length;
  let current = 0;
  let autoTimer: ReturnType<typeof setTimeout> | null = null;

  // ── Layout ──────────────────────────────────────────────
  // Show 2 cards on desktop, 1 on mobile
  let visibleCount = 2;
  const GAP = 24; // matches CSS 1.5rem gap

  function getVisibleCount() {
    return window.innerWidth <= 900 ? 1 : 2;
  }

  function getCardWidth(outer: HTMLElement) {
    const outerW = outer.offsetWidth;
    const vc = getVisibleCount();
    return (outerW - GAP * (vc - 1)) / vc;
  }

  function applyLayout() {
    const outer = track.parentElement as HTMLElement;
    visibleCount = getVisibleCount();
    const w = getCardWidth(outer);
    cards.forEach((c) => {
      c.style.width = w + "px";
      c.style.minWidth = w + "px";
    });
  }

  // ── Navigation ─────────────────────────────────────────
  const maxIndex = () => Math.max(0, total - visibleCount);

  function goTo(index: number, animated = true) {
    current = Math.max(0, Math.min(index, maxIndex()));
    const outer = track.parentElement as HTMLElement;
    const w = getCardWidth(outer);
    const offset = -(current * (w + GAP));

    if (animated) {
      gsap.to(track, {
        x: offset,
        duration: 0.55,
        ease: "power3.inOut",
      });
    } else {
      gsap.set(track, { x: offset });
    }

    // dots
    const dots = Array.from(dotsContainer.querySelectorAll<HTMLElement>(".ts-dot"));
    dots.forEach((d, i) => {
      d.classList.toggle("ts-dot--active", i === current);
    });

    // buttons
    prevBtn.disabled = current === 0;
    nextBtn.disabled = current >= maxIndex();
  }

  function startAuto() {
    stopAuto();
    autoTimer = setInterval(() => {
      goTo(current >= maxIndex() ? 0 : current + 1);
    }, 4500);
  }

  function stopAuto() {
    if (autoTimer !== null) {
      clearInterval(autoTimer);
      autoTimer = null;
    }
  }

  // ── Events ─────────────────────────────────────────────
  prevBtn.addEventListener("click", () => {
    stopAuto();
    goTo(current - 1);
    startAuto();
  });

  nextBtn.addEventListener("click", () => {
    stopAuto();
    goTo(current + 1);
    startAuto();
  });

  dotsContainer.addEventListener("click", (e) => {
    const dot = (e.target as HTMLElement).closest<HTMLElement>(".ts-dot");
    if (!dot) return;
    const idx = Number(dot.dataset.index);
    stopAuto();
    goTo(idx);
    startAuto();
  });

  // Touch swipe
  let touchStartX = 0;
  track.addEventListener("touchstart", (e) => {
    touchStartX = e.touches[0].clientX;
  }, { passive: true });
  track.addEventListener("touchend", (e) => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) < 40) return;
    stopAuto();
    goTo(dx < 0 ? current + 1 : current - 1);
    startAuto();
  }, { passive: true });

  // Resize
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      applyLayout();
      goTo(Math.min(current, maxIndex()), false);
    }, 120);
  });

  // ── Entrance animation ─────────────────────────────────
  gsap.set(cards, { opacity: 0, y: 28 });

  const observer = new IntersectionObserver(
    (entries) => {
      if (!entries[0].isIntersecting) return;
      observer.disconnect();

      gsap.to(cards, {
        opacity: 1,
        y: 0,
        duration: 0.6,
        stagger: 0.1,
        ease: "power3.out",
        clearProps: "transform",
      });
    },
    { threshold: 0.1 }
  );

  // ── Init ───────────────────────────────────────────────
  applyLayout();
  goTo(0, false);
  observer.observe(track);
  startAuto();
</script>
